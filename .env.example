# Dr.Computer environment variables.
#
# Copy this file to `.env` and fill in your values:
#   cp .env.example .env
#
# `.env` is gitignored — your keys will not be committed.

# --- Provider API keys ---

# Aliyun DashScope (Qwen-VL). Get one at:
# https://bailian.console.aliyun.com/ → API-KEY
DASHSCOPE_API_KEY=sk-replace-me

# --- Optional tuning ---

# Override the Qwen model used by examples (default: qwen-vl-max).
# Alternatives: qwen-vl-plus, qwen-vl-max-latest, qwen2.5-vl-72b-instruct
# DR_COMPUTER_QWEN_MODEL=qwen-vl-max

# Override the goal used by examples/01_open_notes.py.
# Leave unset to use the script's default goal.
# DR_COMPUTER_GOAL=Click on the Apple menu in the top-left corner.
